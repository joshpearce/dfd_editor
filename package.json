{
  "name": "dfd-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:flask": "cd server && .venv/bin/flask --app app run --debug --port 5050",
    "dev:all": "concurrently --names 'vite,flask' --prefix-colors 'cyan,yellow' 'npm run dev' 'npm run dev:flask'",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "author": "",
  "dependencies": {
    "d3": "^7.9.0",
    "flexsearch": "^0.8.167",
    "luxon": "^3.7.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin-js": "^4.4.1",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@tsconfig/node22": "^22.0.0",
    "@types/d3": "^7.4.3",
    "@types/jsdom": "^28.0.1",
    "@types/luxon": "^3.4.2",
    "@types/resize-observer-browser": "^0.1.11",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/eslint-plugin": "^1.6.15",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6",
    "concurrently": "^9.0.0"
  }
}

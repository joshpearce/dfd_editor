# Runtime data from container mounts
containers/app/home/vscode/.claude/
containers/proxy/opt/devagent-proxy/logs/*.jsonl

# Python bytecode generated by the mitmproxy filter addon at container runtime
containers/proxy/opt/devagent-proxy/__pycache__/
*.pyc

# Per-worktree environment overrides consumed by docker-compose.worktree.yml
.env

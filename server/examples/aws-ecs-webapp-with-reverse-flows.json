{
    "meta": {
        "name": "AWS ECS Web App (with data items + reverse flows)",
        "description": "Typical AWS deployment of a web application on ECS Fargate, with CloudFront edge caching, an ALB, four containerized services, and managed data/auth tiers. Annotated with data items for each forward flow AND a matching reverse (response) flow for every request/response pair so the editor can render bidirectional pairs.",
        "author": "dfd-editor sample",
        "created": "2026-04-21T12:00:00+00:00"
    },
    "nodes": [
        {
            "type": "external_entity",
            "guid": "40000000-0000-0000-0000-000000000001",
            "properties": {
                "name": "End User",
                "description": "Customer accessing the web app from a browser.",
                "entity_type": "user",
                "out_of_scope": false
            }
        },
        {
            "type": "external_entity",
            "guid": "40000000-0000-0000-0000-000000000002",
            "properties": {
                "name": "Stripe",
                "description": "Third-party payment processor.",
                "entity_type": "service",
                "out_of_scope": true
            }
        },
        {
            "type": "external_entity",
            "guid": "40000000-0000-0000-0000-000000000003",
            "properties": {
                "name": "Amazon Cognito",
                "description": "Managed identity provider for user pools and federated sign-in.",
                "entity_type": "service",
                "out_of_scope": false
            }
        },
        {
            "type": "external_entity",
            "guid": "40000000-0000-0000-0000-000000000004",
            "properties": {
                "name": "Amazon SES",
                "description": "Transactional email sender for receipts and account notifications.",
                "entity_type": "service",
                "out_of_scope": false
            }
        },
        {
            "type": "process",
            "guid": "30000000-0000-0000-0000-000000000001",
            "properties": {
                "name": "CloudFront CDN",
                "description": "Edge cache and TLS termination for static assets and API routes.",
                "trust_level": "system"
            }
        },
        {
            "type": "process",
            "guid": "30000000-0000-0000-0000-000000000002",
            "properties": {
                "name": "Application Load Balancer",
                "description": "Public-facing ALB routing to ECS services by host/path rules.",
                "trust_level": "system"
            }
        },
        {
            "type": "process",
            "guid": "30000000-0000-0000-0000-000000000003",
            "properties": {
                "name": "Web Frontend",
                "description": "ECS Fargate service serving the Vue SPA and proxying auth/API calls.",
                "trust_level": "authenticated",
                "assumptions": [
                    "TLS terminates at ALB; internal hop is plaintext HTTP inside the VPC.",
                    "Session cookies are HttpOnly, Secure, SameSite=Lax."
                ]
            }
        },
        {
            "type": "process",
            "guid": "30000000-0000-0000-0000-000000000004",
            "properties": {
                "name": "REST API",
                "description": "ECS Fargate service exposing the application's CRUD and business-logic endpoints.",
                "trust_level": "authenticated",
                "assumptions": [
                    "Every inbound request carries a JWT minted by the Auth Service.",
                    "Outbound calls to AWS services use the task IAM role, not static keys."
                ]
            }
        },
        {
            "type": "process",
            "guid": "30000000-0000-0000-0000-000000000005",
            "properties": {
                "name": "Auth Service",
                "description": "ECS Fargate service fronting Cognito; issues short-lived JWTs and manages password flows.",
                "trust_level": "admin"
            }
        },
        {
            "type": "process",
            "guid": "30000000-0000-0000-0000-000000000006",
            "properties": {
                "name": "Background Worker",
                "description": "ECS Fargate service polling SQS for async jobs (email, billing reconciliation).",
                "trust_level": "authenticated"
            }
        },
        {
            "type": "data_store",
            "guid": "50000000-0000-0000-0000-000000000001",
            "properties": {
                "name": "ElastiCache Redis",
                "description": "Session cache and rate-limit counters. Volatile; no long-lived PII.",
                "storage_type": "cache",
                "contains_pii": false,
                "encryption_at_rest": true
            }
        },
        {
            "type": "data_store",
            "guid": "50000000-0000-0000-0000-000000000002",
            "properties": {
                "name": "RDS PostgreSQL",
                "description": "Primary relational store: accounts, orders, audit trail.",
                "storage_type": "database",
                "contains_pii": true,
                "encryption_at_rest": true
            }
        },
        {
            "type": "data_store",
            "guid": "50000000-0000-0000-0000-000000000003",
            "properties": {
                "name": "S3 User Uploads",
                "description": "Customer-supplied files (profile photos, attachments). Versioned, KMS-encrypted.",
